# AngularJS Guardian Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# Choose your AI provider: 'codex' or 'openai'
API_PROVIDER=codex

# Codex API Configuration
CODEX_API_KEY=your-codex-api-key-here
CODEX_API_URL=https://api.codex.com/v1
CODEX_MODEL=codex-latest

# OpenAI API Configuration (alternative)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# =============================================================================
# Application Configuration
# =============================================================================

# Base URL of your application
APP_URL=http://localhost:3000

# Routes to test (comma-separated)
APP_ROUTES=/dashboard,/users,/settings,/profile

# Browser Configuration
HEADLESS=false
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# =============================================================================
# Login Configuration
# =============================================================================

# Enable login flow
LOGIN_ENABLED=true

# Login page URL
LOGIN_URL=http://localhost:8080/login

# Application credentials
APP_USERNAME=testuser
APP_PASSWORD=testpassword

# Success URL after login (for validation)
LOGIN_SUCCESS_URL=http://localhost:8080/dashboard

# Login selectors (customize based on your app)
LOGIN_USERNAME_SELECTOR=[name="username"]
LOGIN_PASSWORD_SELECTOR=[name="password"]
LOGIN_SUBMIT_SELECTOR=button[type="submit"]

# =============================================================================
# Java/Tomcat Configuration
# =============================================================================

# Path to Tomcat catalina.out log file
# Windows example: C:\apache-tomcat\logs\catalina.out
# Linux example: /var/log/tomcat/catalina.out
TOMCAT_LOG_PATH=/path/to/catalina.out

# Path to Java source files
JAVA_SRC_PATH=src/main/java

# =============================================================================
# Guardian Behavior Configuration
# =============================================================================

# Maximum attempts per screen before giving up
MAX_SCREEN_ATTEMPTS=10

# Maximum attempts per control before giving up
MAX_CONTROL_ATTEMPTS=3

# Delay between retries (milliseconds)
RETRY_DELAY=2000

# Maximum number of fixes to apply in a single run
MAX_TOTAL_FIXES=20

# Enable verbose logging
DEBUG=false

# =============================================================================
# Git Configuration
# =============================================================================

# Git repository path (usually current directory)
GIT_REPO_PATH=.

# Create backup branch before applying fixes
CREATE_BACKUP_BRANCH=true

# =============================================================================
# Advanced Configuration
# =============================================================================

# Custom selectors for interactive elements (comma-separated)
INTERACTIVE_SELECTORS=button,a,[ng-click],[ng-submit],input[type="submit"]

# Network request timeout (milliseconds)
NETWORK_TIMEOUT=30000

# Console error patterns to ignore (pipe-separated regex)
IGNORE_ERROR_PATTERNS=third-party-script|known-harmless-warning

# HTTP status codes to consider as failures (comma-separated)
FAILURE_STATUS_CODES=400,401,403,404,500,502,503,504,505
